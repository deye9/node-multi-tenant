{
  "name": "node-multi-tenant",
  "version": "2.0.0",
  "description": "Multi-tenant Node.js Application",
  "main": "build/main.js",
  "types": "build/main.d.ts",
  "files": [
    "build",
    "dist",
    "tenants",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node build/main.js",
    "test-watch": "npm run build && mocha \"tests/**/*.test.js\" --watch",
    "eslint": "eslint **/*.js --fix --quiet",
    "coverage": "npm run build && nyc --check-coverage --statements 95 --branches 95 --functions 95 --lines 95 --reporter=html --reporter=text mocha \"tests/**/*.test.js\" --exit",
    "test": "npm run build && nyc --check-coverage --statements 95 --branches 95 --functions 95 --lines 95 --reporter=text mocha \"tests/**/*.test.js\" --exit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deye9/node-multi-tenant.git"
  },
  "keywords": [
    "Multi Tenant",
    "Multi Tenancy"
  ],
  "author": "Adegbenga A. Adeye",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/deye9/node-multi-tenant/issues"
  },
  "homepage": "https://github.com/deye9/node-multi-tenant#readme",
  "dependencies": {
    "auto-bind": "^5.0.1",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "chai-http": "^5.1.2",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.4.2",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "sinon": "^22.0.0",
    "standard": "^17.1.2",
    "typescript": "^6.0.3"
  }
}
